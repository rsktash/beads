# Copy to `.env` and fill in real values. docker-compose reads this file
# automatically. Do NOT commit `.env` (it's in .gitignore).

POSTGRES_DB=tracker
POSTGRES_USER=bd
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# The project prefix used by bd-web's connection string. It must match the
# prefix you used when running `bd init --prefix <name>` from the host.
BD_PREFIX=bd

BD_WEB_PORT=3333
