{
  "name": "@rsktash/bd-web",
  "version": "0.8.5",
  "description": "Web UI for beads issue tracker",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rsktash/beads.git",
    "directory": "web"
  },
  "files": [
    "bin/",
    "server/",
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "bd-web": "bin/bd-web"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"vite --config client/vite.config.ts\" \"node --watch server/index.js\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "node --watch server/index.js",
    "build": "vite build --config client/vite.config.ts",
    "start": "node server/index.js",
    "typecheck": "tsc --noEmit -p client/tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.2",
    "hono": "^4.12.17",
    "marked": "^18.0.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.33",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.10"
  }
}
